---
import Layout from "@/layouts/Layout.astro";
import language from "@/i18n/es/es.ts";
import Hero from "@/components/Hero.astro";
import SectionContainer from "@/components/SectionContainer.astro";
import Experience from "@/components/Experience.astro";
import TitleSection from "@/components/TitleSection.astro";
import Briefcase from "@/components/icons/Briefcase.astro";
import Code from "@/components/icons/Code.astro";
import Book from "@/components/icons/Book.astro";
import Projects from "@/components/Projects.astro";
import Studies from "@/components/Studies.astro";
import Profile from "@/components/icons/Profile.astro";
import AboutMe from "@/components/AboutMe.astro";
---

<Layout language={language}>
  <main
    class="flex flex-col gap-y-20 overflow-hidden px-6 pb-12 md:gap-y-32 md:px-8 md:pb-24"
  >
    <SectionContainer id="hero" class="pt-36 md:pt-48">
      <Hero language={language} />
    </SectionContainer>
    <SectionContainer id="experiencia">
      <TitleSection>
        <Briefcase class="size-8" />
        Experiencia laboral
      </TitleSection>
      <Experience language={language} />
    </SectionContainer>
    <SectionContainer id="proyectos">
      <TitleSection>
        <Code class="size-8" />
        Proyectos
      </TitleSection>
      <Projects language={language} />
    </SectionContainer>
    <SectionContainer id="estudios">
      <TitleSection>
        <Book class="size-8" />
        Estudios
      </TitleSection>
      <Studies language={language} />
    </SectionContainer>
    <SectionContainer id="sobre-mi">
      <TitleSection>
        <Profile class="size-8" />
        Sobre mí
      </TitleSection>
      <AboutMe language={language} />
    </SectionContainer>
  </main>
</Layout>
