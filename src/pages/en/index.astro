---
import Layout from "@/layouts/Layout.astro";
import language from "@/i18n/en/en.ts";
import Hero from "@/components/Hero.astro";
import SectionContainer from "@/components/SectionContainer.astro";
import Experience from "@/components/Experience.astro";
import TitleSection from "@/components/TitleSection.astro";
import Briefcase from "@/components/icons/Briefcase.astro";
import Code from "@/components/icons/Code.astro";
import Book from "@/components/icons/Book.astro";
import Projects from "@/components/Projects.astro";
import Studies from "@/components/Studies.astro";
import Profile from "@/components/icons/Profile.astro";
import AboutMe from "@/components/AboutMe.astro";
---

<Layout language={language}>
  <main
    class="flex flex-col gap-y-16 overflow-hidden px-6 pb-20 md:gap-y-24 md:px-8 md:pb-32"
  >
    <SectionContainer id="hero" class="pt-36 md:pt-48">
      <Hero language={language} />
    </SectionContainer>
    <SectionContainer id="experience">
      <TitleSection>
        <Briefcase class="size-8" />
        Work Experience
      </TitleSection>
      <Experience language={language} />
    </SectionContainer>
    <SectionContainer id="projects">
      <TitleSection>
        <Code class="size-8" />
        Projects
      </TitleSection>
      <Projects language={language} />
    </SectionContainer>
    <SectionContainer id="studies">
      <TitleSection>
        <Book class="size-8" />
        Studies
      </TitleSection>
      <Studies language={language} />
    </SectionContainer>
    <SectionContainer id="about-me">
      <TitleSection>
        <Profile class="size-8" />
        About Me
      </TitleSection>
      <AboutMe language={language} />
    </SectionContainer>
  </main>
</Layout>
