---
import Vue from "@/components/icons/Vue.astro";
import Tailwind from "@/components/icons/Tailwind.astro";
import PHP from "@/components/icons/PHP.astro";
import MySQL from "@/components/icons/MySQL.astro";
import JavaScript from "@/components/icons/JavaScript.astro";
import CSS from "@/components/icons/CSS.astro";
import Docker from "@/components/icons/Docker.astro";
import BrowserFrame from "@/components/BrowserFrame.astro";
import LinkButton from "@/components/icons/LinkButton.astro";
import Github from "@/components/icons/Github.astro";
import Eye from "./icons/eye.astro";
import SpringBoot from "@/components/icons/SpringBoot.astro";
import TypeScript from "./icons/TypeScript.astro";
import Close from "./icons/Close.astro";
import type { Translation } from "@/i18n/types";

interface Props {
  title: string;
  description: string;
  repositories: { label: string; url: string }[];
  image: string;
  imageAlt: string;
  languages: string[];
  url: string;
  language: Translation;
  onDevelopment?: string;
}

const {
  title,
  description,
  repositories,
  image,
  imageAlt,
  languages,
  url,
  language,
  onDevelopment,
} = Astro.props;

const TAGS: Record<
  string,
  { name: string; class: string; icon: any; iconClass?: string }
> = {
  Vue: {
    name: "Vue.js",
    class: "bg-[#41b883] text-white",
    icon: Vue,
    iconClass: "size-3.5",
  },
  TailwindCSS: {
    name: "Tailwind CSS",
    class: "bg-[#003159] text-white",
    icon: Tailwind,
  },
  PHP: {
    name: "PHP",
    class: "bg-[#777bb4] text-white",
    icon: PHP,
    iconClass: "h-4 w-auto",
  },
  MySQL: {
    name: "MySQL",
    class: "bg-[#4479a1] text-white",
    icon: MySQL,
  },
  JavaScript: {
    name: "JavaScript",
    class: "bg-[#f7df1e] text-black",
    icon: JavaScript,
  },
  CSS: {
    name: "CSS",
    class: "bg-[#1572b6] text-white",
    icon: CSS,
  },
  Docker: {
    name: "Docker",
    class: "bg-[#2c3e50] text-white",
    icon: Docker,
  },
  "Spring Boot": {
    name: "Spring Boot",
    class: "bg-[#6db33f] text-white",
    icon: SpringBoot,
  },
  TypeScript: {
    name: "TypeScript",
    class: "bg-[#3178c6] text-white",
    icon: TypeScript,
  },
};

const tags = languages.map((langName) => {
  const tag = TAGS[langName];
  return (
    tag || {
      name: langName,
      class: "bg-gray-600 text-white",
      icon: null,
      iconClass: "",
    }
  );
});
---

<div class="w-full md:w-1/2 md:flex-shrink-0">
  {
    title !== "Repair Shop" && (
      <a href={repositories[0].url} target="_blank" rel="noopener noreferrer">
        <BrowserFrame image={image} alt={imageAlt} url={url} />
      </a>
    )
  }
  {
    title === "Repair Shop" && (
      <div
        class="relative flex aspect-video w-full animate-pulse cursor-pointer flex-col items-center justify-center overflow-hidden rounded-lg border border-indigo-500 bg-gray-300/50 shadow-xl dark:border-yellow-400 dark:bg-gray-800/50"
        data-open-repair-modal
      >
        <p class="text-xl font-bold text-indigo-500 dark:text-yellow-400">
          {language.onDevelopment}
        </p>
      </div>
    )
  }
</div>
<div class="flex-row md:w-1/2">
  <div>
    <h3 class="mb-3 text-2xl font-semibold">
      {
        title !== "Repair Shop" && (
          <a
            href={repositories[0].url}
            class="text-indigo-500 transition-colors duration-200 hover:cursor-pointer hover:text-indigo-950 dark:text-yellow-400 dark:hover:text-indigo-500"
          >
            {title}
          </a>
        )
      }
      {
        title === "Repair Shop" && (
          <button
            type="button"
            data-open-repair-modal
            class="text-indigo-500 transition-colors duration-200 hover:cursor-pointer hover:text-indigo-950 dark:text-yellow-400 dark:hover:text-indigo-500"
          >
            {title}
          </button>
        )
      }
    </h3>
  </div>
  <ul class="mb-3 flex flex-row flex-wrap gap-2">
    {
      tags.map((tag) => (
        <li>
          <span
            class={`flex items-center gap-x-2 rounded-full text-xs ${tag.class} px-2 py-1`}
          >
            {tag.icon && <tag.icon class={tag.iconClass || "size-4"} />}
            {tag.name}
          </span>
        </li>
      ))
    }
  </ul>
  <p class="mb-3 text-justify leading-8">{description}</p>
  <footer class="flex flex-wrap gap-2">
    {
      repositories.map((repo) => (
        <LinkButton href={repo.url}>
          <Github />
          {repo.label}
        </LinkButton>
      ))
    }
    {
      title == "Dom Books" && (
        <LinkButton href="https://dom-books.vercel.app/">
          <Eye />
          {language.demo}
        </LinkButton>
      )
    }
  </footer>
</div>

{
  title === "Repair Shop" && (
    <dialog
      data-repair-modal
      class="m-auto w-full max-w-md rounded-2xl border border-indigo-200 bg-white text-gray-900 shadow-2xl backdrop:bg-black/60 dark:border-yellow-300/40 dark:bg-gray-900 dark:text-gray-100"
    >
      <div class="flex flex-col p-6">
        <div class="mb-4 flex items-start justify-between gap-4">
          <div>
            <h4 class="text-xl font-bold text-indigo-500 dark:text-yellow-500">
              {title}
            </h4>
          </div>
          <button
            type="button"
            data-close-repair-modal
            aria-label="Cerrar modal"
            class="group inline-flex items-center justify-center rounded-full p-2 text-gray-500 transition-all duration-200 hover:bg-indigo-100 hover:text-indigo-600 dark:text-gray-400 dark:hover:bg-gray-800 dark:hover:text-yellow-400"
          >
            <Close class="size-5 cursor-pointer transition-transform duration-300 group-hover:scale-110 group-hover:rotate-90" />
          </button>
        </div>

        <div class="flex flex-col gap-6 md:flex-row">
          {repositories.map((repo) => (
            <div class="flex flex-1">
              <LinkButton
                href={repo.url}
                class="w-full max-w-none justify-center py-3"
              >
                <Github />
                <span>{repo.label}</span>
              </LinkButton>
            </div>
          ))}
        </div>
      </div>
    </dialog>
  )
}

<script is:inline>
  document.querySelectorAll("[data-repair-modal]").forEach((modal) => {
    const container = modal.closest("article");
    if (!container) {
      return;
    }

    const openButtons = container.querySelectorAll("[data-open-repair-modal]");
    const closeButton = modal.querySelector("[data-close-repair-modal]");

    openButtons.forEach((button) => {
      button.addEventListener("click", () => {
        modal.showModal();
      });
    });

    closeButton?.addEventListener("click", () => {
      modal.close();
    });

    modal.addEventListener("click", (event) => {
      if (event.target === modal) {
        modal.close();
      }
    });
  });
</script>
