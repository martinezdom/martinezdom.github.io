---
import ThemeToggle from "./ThemeToggle.astro";

const currentYear = new Date().getFullYear();
const { language } = Astro.props;
---

<div class="flex w-full justify-center px-4 pb-8 md:px-0">
  <footer
    class="mx-auto flex w-full max-w-4xl flex-col items-center justify-between gap-4 rounded-3xl border border-indigo-500/40 bg-indigo-500/10 px-6 py-4 shadow-lg backdrop-blur-lg md:grid md:grid-cols-3 md:gap-4 md:rounded-full dark:border-white/10 dark:bg-slate-900/50"
  >
    <div
      class="order-2 flex w-full flex-row flex-wrap items-center justify-center gap-x-2 gap-y-1 md:order-none md:col-span-2 md:grid md:w-auto md:grid-cols-2 md:gap-4"
    >
      <div
        class="flex items-center text-sm font-medium whitespace-nowrap text-zinc-800/90 md:justify-start md:text-base dark:text-gray-300"
      >
        &copy; {currentYear}
      </div>

      <div class="flex items-center md:justify-center">
        <span
          class="flex items-center gap-1 text-sm font-medium text-zinc-800/90 md:text-base dark:text-gray-300"
        >
          {language.developedBy}
          <a
            href="https://github.com/martinezdom"
            target="_blank"
            class="signature signature-yellow font-bold tracking-wider text-indigo-600 transition-colors hover:text-indigo-800 dark:text-yellow-400 dark:hover:text-yellow-200/90"
          >
            martinezdom</a
          >
        </span>
      </div>
    </div>

    <div
      class="order-1 flex items-center justify-center md:order-none md:justify-end"
    >
      <ThemeToggle language={language} position="bottom" />
    </div>
  </footer>
</div>
