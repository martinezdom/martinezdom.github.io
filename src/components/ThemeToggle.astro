---
import SunIcon from "./icons/Sun.astro";
import MoonIcon from "./icons/Moon.astro";
import SystemIcon from "./icons/System.astro";
const { language, position = "top" } = Astro.props;

const THEMES = [
  { label: language.themes.light, value: "light", icon: SunIcon },
  { label: language.themes.dark, value: "dark", icon: MoonIcon },
  { label: language.themes.system, value: "system", icon: SystemIcon },
];

const buttonClasses =
  "rounded-full flex items-center justify-center size-10 border-2 border-indigo-500 dark:border-yellow-500 text-indigo-500 dark:text-yellow-400 bg-white/80 dark:bg-slate-800/80 backdrop-blur-sm hover:border-indigo-500 hover:bg-indigo-500 hover:text-white hover:scale-110 dark:hover:bg-yellow-500 dark:hover:border-yellow-500 dark:hover:text-slate-900 cursor-pointer transition-all duration-300 shadow-lg hover:shadow-indigo-500/50 dark:hover:shadow-yellow-500/50 aria-[expanded=true]:bg-indigo-500 aria-[expanded=true]:text-white aria-[expanded=true]:border-indigo-500 aria-[expanded=true]:scale-110 aria-[expanded=true]:shadow-indigo-500/50 aria-[expanded=true]:dark:bg-yellow-500 aria-[expanded=true]:dark:border-yellow-500 aria-[expanded=true]:dark:text-slate-900 aria-[expanded=true]:dark:shadow-yellow-500/50";

const menuPositionClass =
  position === "bottom" ? "bottom-full mb-1.5" : "top-full mt-1.5";
---

<div
  class="theme-toggle-container relative z-50 flex items-center justify-center"
>
  <button
    id="theme-toggle"
    aria-expanded="false"
    class={`${buttonClasses} theme-toggle-glitter relative glitter p-1 z-10`}
    aria-haspopup="menu"
  >
    <span class="sr-only">{language.themes.selectorText}</span>

    <span
      id="light"
      class="theme-main-icon absolute inset-0 m-auto flex size-5 items-center justify-center"
    >
      <SunIcon />
    </span>
    <span
      id="dark"
      class="theme-main-icon absolute inset-0 m-auto flex size-5 items-center justify-center"
    >
      <MoonIcon />
    </span>
    <span
      id="system"
      class="theme-main-icon absolute inset-0 m-auto flex size-5 items-center justify-center"
    >
      <SystemIcon />
    </span>
  </button>

  <div
    id="theme-menu"
    class="pointer-events-none absolute top-1/2 right-full mr-2 flex translate-x-8 -translate-y-1/2 flex-row items-center gap-2 rounded-full border border-indigo-500/20 bg-slate-100 px-3 py-1.5 opacity-0 shadow-lg backdrop-blur-md transition-all duration-300 ease-in-out dark:border-white/10 dark:bg-slate-900"
    role="menu"
    aria-labelledby="theme-toggle"
  >
    {
      THEMES.map((theme) => (
        <button
          class="theme-option flex size-8 cursor-pointer items-center justify-center rounded-full text-zinc-500 transition-colors hover:bg-indigo-100 hover:text-indigo-600 dark:text-zinc-400 dark:hover:bg-white/10 dark:hover:text-yellow-400"
          data-theme={theme.value}
          role="menuitem"
          aria-label={theme.label}
          title={theme.label}
        >
          <span class="sr-only">{theme.label}</span>
          <span class="flex size-4 items-center justify-center">
            <theme.icon />
          </span>
        </button>
      ))
    }
  </div>
</div>

<script is:inline>
  const themeToggle = document.getElementById("theme-toggle");
  const themeMenu = document.getElementById("theme-menu");
  const themeIcons = document.querySelectorAll(".theme-main-icon");
  const themeOptions = document.querySelectorAll(".theme-option");
  const colorScheme = window.matchMedia("(prefers-color-scheme: dark)");

  const getSavedTheme = () => {
    const saved = localStorage.getItem("theme");
    return ["light", "dark", "system"].includes(saved) ? saved : "system";
  };

  const updateActiveIcon = (theme) => {
    themeIcons.forEach((icon) => {
      const isActive = icon.id === theme;
      icon.classList.toggle("opacity-100", isActive);
      icon.classList.toggle("opacity-0", !isActive);
    });

    themeOptions.forEach((option) => {
      const isActive = option.dataset.theme === theme;
      if (isActive) {
        option.classList.remove("text-zinc-500", "dark:text-zinc-400");
        option.classList.add(
          "bg-indigo-100",
          "text-indigo-600",
          "dark:bg-white/10",
          "dark:text-yellow-400",
        );
      } else {
        option.classList.add("text-zinc-500", "dark:text-zinc-400");
        option.classList.remove(
          "bg-indigo-100",
          "text-indigo-600",
          "dark:bg-white/10",
          "dark:text-yellow-400",
        );
      }
    });
  };

  const applyTheme = () => {
    const theme = getSavedTheme();
    const isDark =
      theme === "dark" || (theme === "system" && colorScheme.matches);

    document.documentElement.classList.toggle("dark", isDark);
    updateActiveIcon(theme);
  };

  const toggleThemeMenu = () => {
    const isOpen = themeToggle.getAttribute("aria-expanded") === "true";

    if (isOpen) {
      closeThemeMenu();
    } else {
      openThemeMenu();
    }
  };

  const openThemeMenu = () => {
    themeMenu.classList.remove(
      "opacity-0",
      "pointer-events-none",
      "translate-x-8",
    );
    themeMenu.classList.add("opacity-100", "translate-x-0");
    themeToggle.setAttribute("aria-expanded", "true");
  };

  const closeThemeMenu = () => {
    themeMenu.classList.remove("opacity-100", "translate-x-0");
    themeMenu.classList.add(
      "opacity-0",
      "pointer-events-none",
      "translate-x-8",
    );
    themeToggle.setAttribute("aria-expanded", "false");
  };

  const changeTheme = (theme) => {
    localStorage.setItem("theme", theme);
    applyTheme();
    closeThemeMenu();
  };

  themeToggle.addEventListener("click", (e) => {
    e.stopPropagation();
    toggleThemeMenu();
  });

  document.addEventListener("click", (e) => {
    if (!themeToggle.contains(e.target) && !themeMenu.contains(e.target)) {
      closeThemeMenu();
    }
  });

  themeOptions.forEach((option) => {
    option.addEventListener("click", () => {
      changeTheme(option.dataset.theme);
    });
  });

  colorScheme.addEventListener("change", applyTheme);
  document.addEventListener("astro:after-swap", applyTheme);

  applyTheme();
</script>
