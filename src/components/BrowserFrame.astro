---
interface Props {
  image: string;
  alt: string;
  url: string;
}

const { image, alt, url } = Astro.props;
---

<div
  class="relative block w-full overflow-hidden rounded-lg bg-gray-900 shadow-xl"
>
  <div
    class="flex items-center gap-x-2 border-b border-white/5 bg-gray-800/50 px-4 py-2"
  >
    <div class="h-3 w-3 rounded-full bg-red-400"></div>
    <div class="h-3 w-3 rounded-full bg-yellow-400"></div>
    <div class="h-3 w-3 rounded-full bg-green-400"></div>

    <div
      class="ml-4 flex-1 rounded-md bg-gray-900/50 px-2 py-1 text-xs text-gray-400"
    >
      {url}
    </div>
  </div>

  <div class="group relative bg-gray-900">
    <img
      src={image}
      alt={alt}
      class="h-auto w-full object-cover transition-transform duration-500 hover:scale-105"
    />
  </div>
</div>
